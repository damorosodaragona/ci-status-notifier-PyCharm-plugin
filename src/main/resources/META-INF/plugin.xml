<idea-plugin>
    <id>com.damorosodaragona.jenkinsnotifier</id>
    <name>CI Status Notifier</name>
    <vendor>Dario Amoroso d’Aragona</vendor>

    <description>
        Watches GitHub commit statuses for the current Git commit and shows IDE notifications when Jenkins-backed CI changes state.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.damorosodaragona.jenkinsnotifier.CiStatusSettings"/>
        <projectConfigurable
            instance="com.damorosodaragona.jenkinsnotifier.CiStatusConfigurable"
            parentId="tools"
            displayName="CI Status Notifier"/>
        <postStartupActivity implementation="com.damorosodaragona.jenkinsnotifier.CiStatusStartupActivity"/>
        <toolWindow
            id="CI Status"
            anchor="right"
            factoryClass="com.damorosodaragona.jenkinsnotifier.CiStatusToolWindowFactory"/>
        <notificationGroup
            id="CI Status Notifier"
            displayType="BALLOON"
            isLogByDefault="true"/>
    </extensions>
</idea-plugin>
