<idea-plugin>
    <id>com.damorosodaragona.jenkinsnotifier</id>
    <name>Jenkins CI Notifier</name>
    <vendor>Dario Amoroso d’Aragona</vendor>

    <description>
        Monitors Jenkins-backed CI status for the current Git commit and shows IDE notifications when the build state changes.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.damorosodaragona.jenkinsnotifier.CiStatusSettings"/>
        <projectService serviceImplementation="com.damorosodaragona.jenkinsnotifier.LegacySettingsMigrationState"/>
        <projectService serviceImplementation="com.damorosodaragona.jenkinsnotifier.LegacyCiStatusSettings"/>
        <projectConfigurable
            instance="com.damorosodaragona.jenkinsnotifier.CiStatusConfigurable"
            parentId="tools"
            displayName="Jenkins CI Notifier"/>
        <postStartupActivity implementation="com.damorosodaragona.jenkinsnotifier.CiStatusStartupActivity"/>
        <toolWindow
            id="Jenkins CI"
            anchor="right"
            factoryClass="com.damorosodaragona.jenkinsnotifier.CiStatusToolWindowFactory"/>
        <notificationGroup
            id="Jenkins CI Notifier"
            displayType="BALLOON"
            isLogByDefault="true"/>
    </extensions>
</idea-plugin>
